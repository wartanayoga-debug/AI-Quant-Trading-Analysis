# AI Signal Screener local configuration
PORT=3000
APP_ENV=local

# ─── Security ────────────────────────────────────────────────────────────────
# IMPORTANT: Change this before deploying. All admin endpoints (ML training,
# pipeline, rollback) require this password via Authorization: Bearer <password>
# or X-Admin-Password header. If not set, admin endpoints will be LOCKED.
ADMIN_PASSWORD=changeme

# Shared secret between Node.js server and Python bridge.
# If set, all bridge requests must include X-Bridge-Key header.
# Leave empty for local development without bridge auth.
BRIDGE_API_KEY=

# AI Debate / AI Signal Council
AI_DEBATE_MODE=LM_STUDIO_EXPLANATION
AI_DEBATE_ENABLE_LLM_FOR_SCREENER=false
DEEP_SIGNAL_MAX_TOKENS=750
DEEP_SIGNAL_TIMEOUT_MS=90000
DEEP_SIGNAL_INCLUDE_LM_DEBATE=false

# Local AI through LM Studio only
# Both http://127.0.0.1:1234 and http://127.0.0.1:1234/v1 are supported.
LM_STUDIO_BASE_URL=http://127.0.0.1:1234
LM_STUDIO_MODEL=local-model
LM_STUDIO_ANALYSIS_MODEL=
LM_STUDIO_DEBATE_MODEL=
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_TIMEOUT_MS=30000
ENABLE_LM_STUDIO=true
LM_STUDIO_CIRCUIT_MAX_FAILURES=3
LM_STUDIO_CIRCUIT_COOLDOWN_MS=60000

# AI reasoning policy: never use LM Studio on normal asset route unless cached/background eligible.
AI_REASONING_ENABLED=true
AI_REASONING_MODE=top_signals_only
AI_REASONING_MAX_ASSETS_PER_CYCLE=5
AI_REASONING_MIN_CONFIDENCE=70
AI_REASONING_FALLBACK_TO_TEMPLATE=true
AI_CACHE_CRYPTO_TTL_SECONDS=600
AI_CACHE_STOCK_TTL_SECONDS=1800

# Python bridge for pretrained/foundation inference only; no manual ML training
ENABLE_PYTHON_BRIDGE=true
BRIDGE_URL=http://127.0.0.1:8765
BRIDGE_PORT=8765
BRIDGE_TIMEOUT_MS=60000

# Pretrained Chronos forecasting
ENABLE_CHRONOS=true
CHRONOS_BACKEND=auto
CHRONOS_MODEL_ID=amazon/chronos-2
CHRONOS_FALLBACK_MODEL_ID=amazon/chronos-t5-small
CHRONOS_DEVICE=cpu

# Kronos foundation model forecasting
ENABLE_KRONOS=true
KRONOS_MODE=background_cache
KRONOS_REQUEST_TIMEOUT_MS=12000
KRONOS_STALE_AFTER_SECONDS_CRYPTO=900
KRONOS_STALE_AFTER_SECONDS_STOCK=3600
KRONOS_MODEL_ID=NeoQuasar/Kronos-small
KRONOS_TOKENIZER_ID=NeoQuasar/Kronos-Tokenizer-base
KRONOS_MAX_CONTEXT=512
KRONOS_DEVICE=cpu

# Regime detection uses quick local fallback on request path and refreshes HMM in background.
REGIME_MODE=cached_with_fallback
REGIME_REQUEST_TIMEOUT_MS=2500
REGIME_CACHE_TTL_SECONDS=300
REGIME_FAILURE_COOLDOWN_MS=60000

# Background scanner keeps LM Studio off the broad scan path.
BACKGROUND_SCANNER_USE_LM_STUDIO=false
BACKGROUND_SCANNER_GENERATE_AI_FOR_TOP_SIGNALS=true
BACKGROUND_SCANNER_MAX_AI_EXPLANATIONS_PER_CYCLE=5
BACKGROUND_SCANNER_MIN_CONFIDENCE_FOR_AI=70

# Financial news sentiment gate
ENABLE_FINBERT=true
FINBERT_MODEL_ID=ProsusAI/finbert
FINBERT_DEVICE=cpu

# Free public-news sentiment in broad scans. Keep false for faster scans;
# set true when you want scanner rows to use cached FinBERT/news sentiment.
ENABLE_SCAN_SENTIMENT=false
SCAN_SENTIMENT_CACHE_MS=1800000

# Signal quality gate defaults: conservative screener, not trading bot
MIN_SIGNAL_VALIDATION_SCORE=74
# Asset-specific RR floors are used when MIN_RR_RATIO is not set.
MIN_RR_RATIO_IDX=1.80
MIN_RR_RATIO_CRYPTO=1.50
MIN_RR=1.8
MIN_EXPECTED_VALUE_R=0.20
MAX_ACTIONABLE_SIGNALS_PER_DAY=2
ALLOW_REAL_EXECUTION=false
ALLOW_IDX_SHORT=false

# Telegram remote control. Admin commands stay disabled unless explicitly enabled.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_ENABLE_ADMIN_COMMANDS=false
TELEGRAM_REQUIRE_AUTH=true
TELEGRAM_REQUIRE_CONFIRMATION=true
TELEGRAM_RATE_LIMIT_PER_MINUTE=20
